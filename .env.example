# ── World Cup Draft Bot — Environment Variables ────────────────────────────
# Copy this file to .env and fill in the values before starting the bot.
# .env is gitignored. .env.example must hold PLACEHOLDERS only — never real
# tokens, IDs, or passwords. Pushing real secrets here makes them public.

# ── Required: Telegram bot token ───────────────────────────────────────────
# Get this from @BotFather on Telegram:
#   1. Open Telegram, search for @BotFather
#   2. /newbot → follow the prompts (name + username ending in "bot")
#   3. Copy the token it gives you (looks like 123456789:ABCdefGHIjkl...)
#
# IMPORTANT: After creating the bot, also send /setprivacy → Disable to
# BotFather. Without this, the bot can only see commands directed at it
# (/cmd@botname), which is annoying in group chats. With privacy disabled,
# /pick brazil works instead of forcing /pick@worldcupbot brazil.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ── Required: Admin Telegram user IDs (comma-separated) ────────────────────
# Only these users can run /start_league, /start_draft, /set_result, etc.
# To get your user ID, message @userinfobot on Telegram — it replies with
# your numeric ID. For multiple admins: ADMIN_USER_IDS=123456789,987654321
ADMIN_USER_IDS=

# ── Required: League configuration ─────────────────────────────────────────
# Number of players in the league. The bot won't start the draft until
# exactly this many players have run /join. With 48 teams and N players,
# each player gets floor(48/N) or ceil(48/N) countries.
PLAYERS_PER_LEAGUE=5

# ── Required: Database passwords ───────────────────────────────────────────
# Generate strong values:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# MySQL root password (used for the container's root user)
MYSQL_ROOT_PASSWORD=change-me-strong-root-password

# Password for the `worldcup` app user (the one the bot connects as)
DB_PASSWORD=change-me-strong-app-password

# The following are wired in docker-compose.yml and don't need to be in .env:
#   DB_HOST=worldcup_db        ← the service name
#   DB_PORT=3306
#   DB_NAME=worldcup
#   DB_USER=worldcup
#
# Match results are entered manually by the admin via /set_result and
# /set_stage_reached. No external API is used.
